name: Build and Test Pipeline
description: Build, test, and deploy Go application

stages:
  - name: checkout
    image: alpine/git:latest
    script: |
      git clone --depth 1 https://github.com/user/repo.git .
      git checkout {{ .Branch }}
    timeout: 300

  - name: test
    image: golang:1.21-alpine
    script: |
      apk add --no-cache git
      go mod download
      go test -v ./...
      go vet ./...
    timeout: 600
    allow_failure: false

  - name: build
    image: golang:1.21-alpine
    script: |
      CGO_ENABLED=0 GOOS=linux go build -o app .
      ls -lah app
    timeout: 600
    artifacts:
      - app

  - name: build-image
    image: docker:latest
    script: |
      docker build -t myapp:{{ .CommitHash }} .
      docker tag myapp:{{ .CommitHash }} myapp:latest
    timeout: 900
    needs_docker: true
    allow_failure: false

  - name: push-image
    image: docker:latest
    script: |
      docker push registry.io/myapp:{{ .CommitHash }}
      docker push registry.io/myapp:latest
    timeout: 900
    needs_docker: true
    only:
      - main

notifications:
  slack: "#ci-builds"
  email: "team@example.com"

on_failure:
  notify: true
  stop_pipeline: true
